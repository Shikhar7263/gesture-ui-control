# Environment variable overrides for Gesture UI Control
# Copy this file to .env and fill in the values you want to change.
# All variables have sensible defaults and are optional.

# Secret key used by Flask for session signing.
# Change this to a strong random string in production.
# Default: gesture-ui-dev-secret
SECRET_KEY=

# Host interface the Flask server listens on.
# Use 0.0.0.0 to accept connections from other machines on the network.
# Default: 127.0.0.1
GESTURE_HOST=

# TCP port the Flask server listens on.
# Default: 5000
GESTURE_PORT=
